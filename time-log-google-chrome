        "jsCode": "// ─────────────────────────────────────────────────────────\n//  NODE: Check if this task is new (for Slack/notification)\n// ─────────────────────────────────────────────────────────\n// Compares the incoming Teamwork Task ID against existing\n// Task Summary rows to see if we've seen this task before.\n// Output is used for optional Slack notification node.\n\nconst incomingSession = $('Validate & Enrich Session').first().json;\nconst existingTasks   = $input.all().map(i => i.json);\n\nconst taskId    = incomingSession.teamwork_task_id;\nconst taskTitle = incomingSession.title;\n\nconst existing = existingTasks.find(r => String(r['Task ID']) === String(taskId));\n\nreturn [{\n  json: {\n    task_id:          taskId,\n    task_title:       taskTitle,\n    task_url:         incomingSession.url,\n    is_new_task:      !existing,\n    previous_seconds: existing ? parseInt(existing['Total Seconds'] || '0', 10) : 0,\n    previous_hms:     existing ? existing['Total Time (HH:MM:SS)'] || '00:00:00' : '00:00:00',\n  }\n}];\n"
