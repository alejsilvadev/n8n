      "parameters": {
        "jsCode": "// ─────────────────────────────────────────────────────────\n//  NODE: Calculate Task Time Totals\n// ─────────────────────────────────────────────────────────\n//\n//  LOGIC:\n//  Walk through every row in Raw Sessions in chronological order.\n//  Each time we hit a Teamwork Task URL, it becomes the \"active task\".\n//  Every non-task session that follows is attributed to that active task.\n//  We sum up total seconds per task, and also track the sessions within.\n//\n//  Result: one summary row per unique Teamwork Task ID.\n// ─────────────────────────────────────────────────────────\n\nconst allRows = $input.all().map(item => item.json);\n\n// Build a map: taskId → { title, url, totalSeconds, sessionCount, firstSeen, lastSeen, sessions[] }\nconst taskMap = {};\n\nlet activeTaskId    = null;\nlet activeTaskTitle = null;\nlet activeTaskUrl   = null;\n\nfunction toHHMMSS(seconds) {\n  const h = Math.floor(seconds / 3600);\n  const m = Math.floor((seconds % 3600) / 60);\n  const s = seconds % 60;\n  return [h, m, s].map(v => String(v).padStart(2, '0')).join(':');\n}\n\n// Sort rows by start time ascending so we process them in order\nconst sorted = [...allRows].sort((a, b) => {\n  return new Date(a['Start Time'] || 0) - new Date(b['Start Time'] || 0);\n});\n\nfor (const row of sorted) {\n  const isTask   = String(row['Is Teamwork Task']).toLowerCase() === 'true';\n  const taskId   = String(row['Teamwork Task ID'] || '').trim();\n  const duration = parseInt(row['Duration (seconds)'] || '0', 10);\n  const startTime = row['Start Time'] || '';\n\n  if (isTask && taskId) {\n    // This row IS a Teamwork task — it becomes the new active task\n    activeTaskId    = taskId;\n    activeTaskTitle = row['Title'] || `Task #${taskId}`;\n    activeTaskUrl   = row['URL'] || '';\n\n    // Ensure the task entry exists in our map\n    if (!taskMap[activeTaskId]) {\n      taskMap[activeTaskId] = {\n        task_id:          activeTaskId,\n        task_title:       activeTaskTitle,\n        task_url:         activeTaskUrl,\n        total_seconds:    0,\n        session_count:    0,\n        first_seen:       startTime,\n        last_seen:        startTime,\n        attributed_urls:  [],\n      };\n    }\n\n    // The time spent on the task page itself counts too\n    taskMap[activeTaskId].total_seconds += duration;\n    taskMap[activeTaskId].session_count += 1;\n    taskMap[activeTaskId].last_seen = startTime;\n\n  } else if (activeTaskId) {\n    // Regular web session — attribute to the current active Teamwork task\n    if (!taskMap[activeTaskId]) {\n      taskMap[activeTaskId] = {\n        task_id:          activeTaskId,\n        task_title:       activeTaskTitle,\n        task_url:         activeTaskUrl,\n        total_seconds:    0,\n        session_count:    0,\n        first_seen:       startTime,\n        last_seen:        startTime,\n        attributed_urls:  [],\n      };\n    }\n\n    taskMap[activeTaskId].total_seconds += duration;\n    taskMap[activeTaskId].session_count += 1;\n    taskMap[activeTaskId].last_seen = startTime;\n\n    // Keep a deduplicated list of attributed hostnames\n    const hostname = row['Hostname'] || '';\n    if (hostname && !taskMap[activeTaskId].attributed_urls.includes(hostname)) {\n      taskMap[activeTaskId].attributed_urls.push(hostname);\n    }\n  }\n  // If activeTaskId is null, we haven't visited a Teamwork task yet — skip\n}\n\n// Convert map to output rows for Google Sheets upsert\nconst output = Object.values(taskMap).map(t => ({\n  'Task ID':               t.task_id,\n  'Task Title':            t.task_title,\n  'Task URL':              t.task_url,\n  'Total Seconds':         t.total_seconds,\n  'Total Time (HH:MM:SS)': toHHMMSS(t.total_seconds),\n  'Total Hours':           (t.total_seconds / 3600).toFixed(4),\n  'Session Count':         t.session_count,\n  'First Seen':            t.first_seen,\n  'Last Seen':             t.last_seen,\n  'Attributed Sites':      t.attributed_urls.slice(0, 20).join(', '),\n  'Last Updated':          new Date().toISOString(),\n}));\n\nreturn output.map(row => ({ json: row }));\n"
      },
