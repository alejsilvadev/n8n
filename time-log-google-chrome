      "parameters": {
        "jsCode": "// ─────────────────────────────────────────────────────────\n//  NODE: Validate & Enrich Incoming Session\n// ─────────────────────────────────────────────────────────\n// This node cleans up and standardises the payload from\n// the Chrome extension before writing to Google Sheets.\n\nconst body = $input.first().json.body ?? $input.first().json;\n\n// Bail early if this isn't a tab_session event\nif (body.event !== 'tab_session') {\n  return []; // stop processing\n}\n\n// Round seconds to nearest second\nconst durationSec = Math.round(Number(body.duration_seconds) || 0);\n\n// Format duration as HH:MM:SS for readability in Sheets\nfunction toHHMMSS(seconds) {\n  const h = Math.floor(seconds / 3600);\n  const m = Math.floor((seconds % 3600) / 60);\n  const s = seconds % 60;\n  return [h, m, s].map(v => String(v).padStart(2, '0')).join(':');\n}\n\n// Derive a friendly page category\nfunction categorise(hostname, isTeamworkTask) {\n  if (isTeamworkTask) return 'Teamwork Task';\n  if (/mail\\.google|outlook\\.com|gmail/i.test(hostname)) return 'Email';\n  if (/github\\.com|gitlab\\.com/i.test(hostname)) return 'Code';\n  if (/slack\\.com|teams\\.microsoft|discord\\.com/i.test(hostname)) return 'Chat';\n  if (/stackoverflow\\.com|stackexchange\\.com/i.test(hostname)) return 'Research';\n  if (/docs\\.google|notion\\.so|confluence/i.test(hostname)) return 'Docs';\n  if (/youtube\\.com|vimeo\\.com/i.test(hostname)) return 'Video';\n  if (/teamwork\\.com/i.test(hostname)) return 'Teamwork (other)';\n  return 'Web';\n}\n\nconst hostname       = body.hostname || '';\nconst isTeamworkTask = body.is_teamwork_task === true;\nconst taskId         = body.teamwork_task_id || '';\nconst category       = categorise(hostname, isTeamworkTask);\n\nreturn [{\n  json: {\n    // Raw fields from extension\n    event:              body.event,\n    url:                body.url || '',\n    title:              (body.title || '').slice(0, 200),  // cap length\n    hostname,\n    is_teamwork_task:   isTeamworkTask,\n    teamwork_task_id:   taskId,\n    start_time:         body.start_time || new Date().toISOString(),\n    end_time:           body.end_time   || new Date().toISOString(),\n    duration_seconds:   durationSec,\n    duration_hms:       toHHMMSS(durationSec),\n    reason:             body.reason || '',\n    // Enriched fields\n    category,\n    logged_at:          new Date().toISOString(),\n    date:               new Date(body.start_time || Date.now()).toISOString().slice(0, 10),\n  }\n}];\n"
      },
